# davey's mako config

max-history=5
sort=+time

on-button-left=invoke-default-action
on-button-right=dismiss
on-button-middle=dismiss-group

font= JetBrainsMono 12
background-color=#2b303bb3
text-color=#ffffff

width=300
height=100

outer-margin=1
margin=0

padding=10

border-size=1
border-color=#ffd1dc
border-radius=0
progress-color=over #c98b9a

icons=0
actions=1
history=1

format= <b>%s</b>\n%b
text-alignment=left

default-timeout=10000
ignore-timeout=0
max-visible=5
layer=top
anchor=top-right
